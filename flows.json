    {
        "id": "c199f7e3ee91bf3a",
        "type": "function",
        "z": "92ccb742f557b4af",
        "name": "ELEVENLABS PAYLOAD",
        "func": "// 1. Pull current live metrics from memory\nlet temp = parseFloat(flow.get(\"latest_temp\") || 100);\nlet hum = parseFloat(flow.get(\"latest_hum\") || 70.2);\nlet soil = parseInt(flow.get(\"latest_soil\") || 9);\n\nlet advice = \"\";\n\n// 2. Data Analytics Decision Tree Logic (Agricultural Consultation Focus)\nif (temp > 30 && soil < 40) {\n    advice = `Botanical Consultation: Ambient temperature is critical at ${temp}C, causing rapid soil moisture depletion down to ${soil}%. The high heat load is putting your crops at risk of heat stress. I highly recommend engaging the exhaust fan immediately to lower the ambient heat index.`;\n} else if (temp > 30) {\n    advice = `Botanical Consultation: High thermal threshold detected at ${temp}C. While soil hydration is currently stable, sustained ambient heat can accelerate transpirational stress. Activating the greenhouse exhaust fan is recommended to restore optimal climate balance.`;\n} else if (soil < 40) {\n    advice = `Botanical Consultation: Soil moisture levels have dropped to an insufficient ${soil}%. The roots are searching for hydration, which will slow down overall biomass accumulation. Please look into watering the greenhouse beds soon to maintain soil health.`;\n} else {\n    advice = `Botanical Consultation: All environmental core parameters are perfectly balanced. Temperature is ${temp}C, Humidity is ${hum}%, and Soil Moisture is ${soil}%. The greenhouse microclimate is currently optimal for maximum crop growth.`;\n}\n\n// 3. Construct clean standard JSON payload for ElevenLabs TTS\nmsg.headers = {\n    \"xi-api-key\": \"0b086fcdb95972d164fbefa31e1dd75ce7c80d09c0c4257634515a57f8e4cdf1\",\n    \"Content-Type\": \"application/json\",\n    \"accept\": \"application/json\"\n};\n\nmsg.payload = {\n    text: advice,\n    model_id: \"eleven_monolingual_v1\",\n    voice_settings: {\n        stability: 0.5,\n        similarity_boost: 0.5\n    }\n};\n\n// Store the plain text analysis so your UI can display it immediately\nflow.set(\"last_ai_analysis\", advice);\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 40,
        "wires": [
